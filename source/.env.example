COMPOSE_PROJECT_NAME = openproject_custom_stack

#Postgres DB variables
DB_USER = postgres
DB_PASSWORD = CHANGE-ME
DB_VERSION_TAG = 17
DB_PORT = 5432


#Openproject APP variables
